body {
    font-family: Arial, sans-serif;
    background: #eef4f8;
    margin: 0;
}

/* Layout */
.result-container {
    display: flex;
    justify-content: center;
    gap: 40px;
    padding: 40px;
}

/* Summary Card */
.summary-card {
    width: 300px;
    background: white;
    padding: 25px;
    border-radius: 15px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    text-align: center;
}

/* Value Box */
.value-box {
    background: #4CAFED;
    color: white;
    padding: 20px;
    border-radius: 12px;
}

.value-box h3 {
    margin-top: 5px;
}

/* Center Button */
.center-btn {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 25px;
}


/* Button */
.back-btn {
    padding: 12px 25px;
    border: none;
    background: #2c3e50;
    color: white;
    border-radius: 10px;
    cursor: pointer;
}

.back-btn:hover {
    background: #1a252f;
}

/* Graph Card */
.graph-card {
    width: 500px;
    background: white;
    padding: 25px;
    border-radius: 15px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    text-align: center;
}
/* Bottom Button Container */
/* Bottom Button Container */
/* Bottom Fixed Button Container */
.bottom-btn-container {
    width: 100%;
    display: flex;
    justify-content: center;
    position: fixed;     /* 👈 Makes it stay at bottom */
    bottom: 25px;        /* Space from bottom */
    left: 0;
}
.predict-again-btn {
    padding: 8px 22px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    color: white;
    background: linear-gradient(135deg, #4CAFED, #2c8bd8);
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    transition: 0.3s ease;
}

.predict-again-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 15px rgba(0,0,0,0.2);
}


/* Remove Pulse Animation (Cleaner Look) */
.predict-again-btn::after {
    display: none;
}
.model-breakdown {
    margin-top: 15px;
    font-size: 13px;
    color: #555;
    background: #f3f7fb;
    padding: 10px;
    border-radius: 8px;
}

.model-breakdown p {
    margin: 4px 0;
}
.model-breakdown {
    margin-top: 15px;
    background: #f3f7fb;
    padding: 15px;
    border-radius: 12px;
    box-shadow: inset 0 1px 4px rgba(0,0,0,0.05);
}

/* Each Row */
.model-breakdown p {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 8px 0;
    font-size: 14px;
    color: #34495e;
    font-weight: 500;
}

/* Optional Hover Effect */
.model-breakdown p:hover {
    background: rgba(76,175,237,0.08);
    padding: 6px 8px;
    border-radius: 8px;
    transition: 0.3s;
}
.result-container {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-top: 40px;
}

/* LEFT COLUMN */
.left-column {
    width: 35%;
    display: flex;
    flex-direction: column;
    gap: 20px;
}

/* RIGHT COLUMN */
.right-column {
    width: 40%;
}
/* Risk Boxes */
.risk-normal { background: #2ecc71; color: white; padding: 10px; border-radius: 10px; margin-top: 15px; }
.risk-mild { background: #f1c40f; color: white; padding: 10px; border-radius: 10px; margin-top: 15px; }
.risk-moderate { background: #e67e22; color: white; padding: 10px; border-radius: 10px; margin-top: 15px; }
.risk-severe { background: #e74c3c; color: white; padding: 10px; border-radius: 10px; margin-top: 15px; }

.explanation {
    margin-top: 10px;
    font-size: 14px;
    color: #34495e;
}

.deviation {
    margin-top: 8px;
    font-weight: 600;
}

.conditions-box {
    margin-top: 15px;
    background: #f4f7fb;
    padding: 12px;
    border-radius: 10px;
}

.conditions-box ul {
    margin: 8px 0 0 15px;
}
.metrics-section {
    margin-top: 30px;
}

.metrics-grid {
    display: flex;
    gap: 20px;
}

.metric-card {
    flex: 1;
    background: linear-gradient(135deg, #1f2937, #111827);
    padding: 20px;
    border-radius: 12px;
    text-align: center;
    color: white;
    box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    transition: transform 0.3s ease;
}

.metric-card:hover {
    transform: translateY(-5px);
}

.metric-card h3 {
    margin-bottom: 10px;
    font-size: 16px;
    opacity: 0.8;
}

.metric-card p {
    font-size: 24px;
    font-weight: bold;
    color: #22d3ee;
}
/* ===== Diagnosis Section ===== */

.diagnosis-section{
    margin-top:40px;
}

/* Header */

.diagnosis-header{
    display:flex;
    align-items:center;
    gap:10px;
    margin-bottom:20px;
}

.lung-icon{
    font-size:26px;
}

.diagnosis-header h2{
    font-size:24px;
    font-weight:600;
    color:#1e293b;
}

/* Card */

.diagnosis-card{
    background:#ffffff;
    border-radius:12px;
    padding:25px;
    box-shadow:0 8px 25px rgba(0,0,0,0.08);
    border-left:8px solid #ef4444;
}

/* Disease title */

.disease-title{
    font-size:22px;
    font-weight:700;
    color:#111827;
    margin-bottom:10px;
}

/* Explanation */

.disease-explanation{
    font-size:16px;
    color:#374151;
    line-height:1.6;
    margin-bottom:20px;
}

/* Conditions list */

.conditions-box{
    background:#f8fafc;
    padding:18px;
    border-radius:10px;
}

.conditions-box h4{
    margin-bottom:10px;
    font-size:16px;
    color:#111827;
}

.conditions-box ul{
    padding-left:18px;
}

.conditions-box li{
    margin-bottom:6px;
    font-size:15px;
    color:#1f2937;
}

/* Risk Colors */

.risk-normal{
    border-left-color:#22c55e;
}

.risk-mild{
    border-left-color:#facc15;
}

.risk-moderate{
    border-left-color:#f97316;
}

.risk-severe{
    border-left-color:#ef4444;
}

.risk-obstructive{
    border-left-color:#3b82f6;
}
.clinical-section{
    margin-top:30px;
    background:white;
    padding:25px;
    border-radius:12px;
    box-shadow:0 6px 20px rgba(0,0,0,0.08);
}

.clinical-section h2{
    font-size:20px;
    margin-bottom:10px;
}

.clinical-text{
    font-size:15px;
    line-height:1.6;
    color:#374151;
}
.recommendation-section{
    margin-top:25px;
    background:#f8fafc;
    padding:20px;
    border-radius:10px;
    border-left:6px solid #4CAFED;
}

.recommendation-section h2{
    font-size:18px;
    margin-bottom:8px;
}

.recommendation-text{
    font-size:15px;
    color:#374151;
    line-height:1.6;
}