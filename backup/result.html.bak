<!DOCTYPE html>
<html>
<head>
    <title>TLC Result</title>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <link rel="stylesheet" href="{{ url_for('static', filename='result.css') }}">
</head>

<body>

<div class="result-container">

    <!-- LEFT COLUMN -->
    <div class="left-column">

        <!-- TLC CARD -->
        <div class="summary-card">

            <h2>🫁 Total lung capacity Prediction Result</h2>

            <div class="value-box highlight">
                <p>Your Predicted Capacity</p>
                <h3>{{ final }} L</h3>
            </div>
            <!-- CLINICAL SUMMARY BLOCK -->


        </div>

    </div>


    <!-- RIGHT COLUMN -->
    <div class="right-column">

        <div class="graph-card">
            <h2>Lung Capacity Comparison</h2>
            <canvas id="tlcChart"></canvas>
        </div>

    </div>

</div>
<div class="health-score-card {{ health_color }}">

    <h2>🫁 Lung Health Score</h2>

    <div class="score-value">
        {{ health_score }} / 100
    </div>

    <div class="score-status">
        {{ health_status }}
    </div>

    <p class="score-note">
        This score represents how close your predicted lung capacity
        is to the expected healthy range for your demographic.
    </p>

</div>
<div class="clinical-section">

    <h2>Clinical Interpretation</h2>

    <p class="clinical-text">
        {{ clinical_interpretation }}
    </p>

</div>
<div class="feature-importance-section">

    <h2>📊 Feature Importance</h2>

    <canvas id="featureChart"></canvas>

</div>
<div class="recommendation-section">

    <h2>Recommendation</h2>

    <p class="recommendation-text">
        {{ recommendation }}
    </p>

</div>
<!-- BUTTON OUTSIDE BOTH COLUMNS -->
<div class="bottom-btn-container">
    <a href="/" class="predict-again-btn">
        🔄 Predict Again
    </a>
</div>

<div class="diagnosis-section">

    <div class="diagnosis-header">
        <span class="lung-icon">🫁</span>
        <h2>Lung Condition Analysis</h2>
    </div>

    <div class="diagnosis-card {{ risk_class }}">

        <h3 class="disease-title">{{ disease }}</h3>

        <p class="disease-explanation">
            {{ explanation }}
        </p>

        <div class="conditions-box">
            <h4>Possible Conditions</h4>

            <ul>
                {% for condition in possible_conditions %}
                <li>{{ condition }}</li>
                {% endfor %}
            </ul>

        </div>

    </div>

</div>
<script>

const ctx = document.getElementById('tlcChart');

new Chart(ctx, {
    type: 'bar',
    data: {
        labels: ['Ideal', 'Former', 'Current', 'Your Capacity'],
        datasets: [{
            label: 'Capacity (Liters)',
            data: [
                {{ ideal_tlc }},
                {{ former_tlc }},
                {{ current_tlc }},
                {{ final }}
            ]
        }]
    },

    options: {
        responsive: true,
        scales: {
            y: {
                beginAtZero: true,
                title: {
                    display: true,
                    text: 'Liters'
                }
            }
        }
    }
});
const featureCtx = document.getElementById('featureChart');

new Chart(featureCtx, {
    type: 'bar',

    data: {
        labels: {{ feature_labels | tojson }},
        datasets: [{
            label: 'Importance',
            data: {{ feature_values | tojson }},
        }]
    },

    options: {
        responsive: true,
        indexAxis: 'y',

        scales: {
            x: {
                beginAtZero: true,
                title: {
                    display: true,
                    text: 'Importance Score'
                }
            }
        }
    }

});
</script>

</body>
</html>

